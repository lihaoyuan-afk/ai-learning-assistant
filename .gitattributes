# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly LF for source files
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binary — never modify line endings
*.pdf   binary
*.db    binary
*.sqlite3 binary
